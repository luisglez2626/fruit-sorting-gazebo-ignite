<?xml version="1.0"?>
<!-- 
==============================================================================
File: collaborative_arm.urdf.xacro
Purpose: The main Xacro file that defines the physical structure of the robot.
         Restored to explicitly include both gripper fingers in ros2_control
         without relying on the mimic tag.
==============================================================================
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="collaborative_arm">

  <link name="world"/>

  <link name="pedestal">
    <visual>
      <geometry><box size="0.4 0.4 0.5"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.4 0.4 0.5"/></geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <joint name="world_to_pedestal" type="fixed">
    <parent link="world"/>
    <child link="pedestal"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>

  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro" />

  <xacro:ur_robot
    name="my_ur5"
    tf_prefix=""
    parent="pedestal"
    joint_limits_parameters_file="$(find ur_description)/config/ur5e/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur5e/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur5e/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur5e/visual_parameters.yaml"
    sim_ignition="true"> 
    <origin xyz="0 0 0.25" rpy="0 0 0" />
  </xacro:ur_robot>

  <gazebo>
    <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find collaborative_arm_gazebo)/config/arm_controllers.yaml</parameters>
    </plugin>
    
    <plugin filename="ignition-gazebo-detachable-joint-system" name="ignition::gazebo::systems::DetachableJoint">
      <parent_link>wrist_3_link</parent_link>
      <child_model>red_apple</child_model>
      <child_link>link</child_link>
      <attach_topic>/attach_red</attach_topic>
      <detach_topic>/detach_red</detach_topic>
    </plugin>
    
    <plugin filename="ignition-gazebo-detachable-joint-system" name="ignition::gazebo::systems::DetachableJoint">
      <parent_link>wrist_3_link</parent_link>
      <child_model>green_apple</child_model>
      <child_link>link</child_link>
      <attach_topic>/attach_green</attach_topic>
      <detach_topic>/detach_green</detach_topic>
    </plugin>
  </gazebo>

  <link name="gripper_base">
    <visual>
      <geometry><box size="0.14 0.04 0.04"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.14 0.04 0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="flange_to_gripper" type="fixed">
    <parent link="tool0"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="left_finger">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <gazebo reference="left_finger">
    <visual>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.1 0.1 0.1 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <joint name="gripper_to_left_finger" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="-0.055 0 0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.05" effort="100.0" velocity="0.5"/>
  </joint>

  <link name="right_finger">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <gazebo reference="right_finger">
     <visual>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.1 0.1 0.1 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <!-- Removido el mimic tag para control independiente explícito -->
  <joint name="gripper_to_right_finger" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0.055 0 0.02" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.05" effort="100.0" velocity="0.5"/>
  </joint>

  <link name="camera_link_base">
    <visual>
      <geometry>
        <box size="0.12 0.04 0.03"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1"/>
      </material>
    </visual>
  </link>

  <joint name="gripper_to_camera" type="fixed">
    <parent link="gripper_base"/>
    <child link="camera_link_base"/>
    <origin xyz="0 -0.04 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_left_link">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.005"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="left_lens_joint" type="fixed">
    <parent link="camera_link_base"/>
    <child link="camera_left_link"/>
    <origin xyz="-0.035 -0.01 0.015" rpy="0 0 0"/>
  </joint>

  <link name="camera_right_link">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.005"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_lens_joint" type="fixed">
    <parent link="camera_link_base"/>
    <child link="camera_right_link"/>
    <origin xyz="0.035 -0.01 0.015" rpy="0 0 0"/>
  </joint>

  <link name="camera_math_frame"/>

  <joint name="camera_math_joint" type="fixed">
    <parent link="camera_link_base"/>
    <child link="camera_math_frame"/>
    <origin xyz="-0.035 -0.01 0.015" rpy="0 -1.5708 1.5708"/>
  </joint>

  <gazebo reference="camera_math_frame">
    <sensor name="left_cam" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>left_cam/image_raw</topic>
      <camera name="left">
         <horizontal_fov>1.396</horizontal_fov>
         <image>
           <width>640</width>
           <height>480</height>
         </image>
         <clip>
           <near>0.02</near>
           <far>300</far>
         </clip>
      </camera>
      <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
          <render_engine>ogre2</render_engine>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_right_link">
    <sensor name="right_cam" type="camera">
      <pose>0 0 0 0 -1.5708 1.5708</pose>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>right_cam/image_raw</topic>
      <camera name="right">
         <horizontal_fov>1.396</horizontal_fov>
         <image>
           <width>640</width>
           <height>480</height>
         </image>
         <clip>
           <near>0.02</near>
           <far>300</far>
         </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Añadido explícitamente el right_finger de nuevo al Hardware de control -->
  <ros2_control name="GripperHardware" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin> 
    </hardware>
    <joint name="gripper_to_left_finger">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper_to_right_finger">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <link name="tcp_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <joint name="gripper_to_tcp" type="fixed">
    <parent link="gripper_base"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
  </joint>

</robot>